# --- Railway: постоянные загрузки (аватары, вложения) ---
# В Railway → Service → Volumes: создайте том, mount path: /data/media
# Переменная ниже задаётся автоматически на Railway, если том смонтирован:
# MEDIA_ROOT=/data/media

# --- Или S3 / Cloudflare R2 (файлы не пропадают при рестарте) ---
# AWS_STORAGE_BUCKET_NAME=your-bucket
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION_NAME=auto
# AWS_S3_ENDPOINT_URL=https://xxxx.r2.cloudflarestorage.com
# AWS_S3_CUSTOM_DOMAIN=cdn.example.com
